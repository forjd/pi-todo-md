{
  "name": "pi-todo-md",
  "version": "0.1.2",
  "description": "A shareable pi extension for managing a repo-local TODO.md file.",
  "type": "module",
  "main": "./extensions/todo-md.js",
  "exports": {
    ".": "./extensions/todo-md.js",
    "./src": "./src/todo-md.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forjd/pi-todo-md.git"
  },
  "bugs": {
    "url": "https://github.com/forjd/pi-todo-md/issues"
  },
  "homepage": "https://github.com/forjd/pi-todo-md#readme",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "todo",
    "markdown"
  ],
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/todo-md.js"
    ],
    "image": "https://raw.githubusercontent.com/forjd/pi-todo-md/main/.github/social-preview.png"
  },
  "scripts": {
    "build": "echo 'nothing to build'",
    "check": "node --test",
    "test": "node --test"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
